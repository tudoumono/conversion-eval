# Description:
#   .env のひな形です。必要に応じて .env にコピーします。
#
# パスはプロジェクトルートからの相対パスで書きます。

# Doclingに渡す一時入力ファイルの置き場です。
# 日本語ファイル名や日本語フォルダ名でDoclingが失敗する場合があるため、
# 変換前にASCII名の一時ファイルへコピーしてから処理します。
CONVERSION_EVAL_ASCII_TMP=.tmp/docling

# Hugging Face系モデルのキャッシュ全体の置き場です。
# DoclingはPDF解析やOCRで内部モデルを使うため、初回実行時にモデルをここへ保存します。
# ユーザーホーム配下に依存しないよう、プロジェクト配下の相対パスにしています。
HF_HOME=.tmp/huggingface_nosymlink

# Hugging Face Hubから取得したモデル本体のキャッシュ置き場です。
# HF_HOME配下のhubを明示して、キャッシュ先をこのプロジェクト内に固定します。
HF_HUB_CACHE=.tmp/huggingface_nosymlink/hub

# Windows環境ではシンボリックリンク作成に管理者権限が必要になることがあります。
# 1にするとHugging Face Hubがシンボリックリンクを使わず、通常ファイルとして保存します。
HF_HUB_DISABLE_SYMLINKS=1

# シンボリックリンク無効化に関する警告を抑止します。
# 上の HF_HUB_DISABLE_SYMLINKS=1 を意図的に設定しているためです。
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# モデルダウンロードや読み込み時のプログレスバー表示を抑止します。
# CSVレポートやログ確認時に余計な表示が混ざるのを避けるためです。
HF_HUB_DISABLE_PROGRESS_BARS=1

# LLMを使うかどうか、どのLLMを使うかは .env ではなく
# config/patterns.yaml の uses_llm / llm_provider で制御します。
# 許可するLLMは ollama または openai のみです。
# llm_provider=none または未指定のパターンではLLMを使用しません。

# ネットワーク取得を許可するかどうかは config/patterns.yaml の
# allow_network_download でパターンごとに制御します。
# allow_network_download=false のDocling実行時は、コード側で
# HF_HUB_OFFLINE / TRANSFORMERS_OFFLINE / HF_DATASETS_OFFLINE を有効化します。
